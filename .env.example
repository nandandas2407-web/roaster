# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# GITHUB_TOKEN: Optional public GitHub personal access token to bypass rate limit
GITHUB_TOKEN=""

# VITE_API_URL: Backend API URL for Cloudflare Worker (leave empty for same-origin)
VITE_API_URL="https://roaster-api.YOUR_SUBDOMAIN.workers.dev"
